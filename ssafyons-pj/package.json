{
  "name": "yogiu-vue-env-final",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,VITE \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.2.0",
    "vite": "^6.0.5"
  }
}
